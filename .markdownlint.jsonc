// markdownlint-cli2 configuration
// Relaxed rules suited for training material (long lines in tables, inline HTML in callouts, etc.)
{
  "default": true,
  "MD013": false,
  "MD022": false,
  "MD024": { "siblings_only": true },
  "MD026": false,
  "MD028": false,
  "MD032": false,
  "MD033": false,
  "MD034": false,
  "MD038": false,
  "MD040": false,
  "MD041": false,
  "ignores": [
    "node_modules/**",
    ".remember/**"
  ]
}
